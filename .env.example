# Go relay server — environment variables
# Copy to .env (never commit) or inject via Railway environment variables.
#
# Usage (local dev):  set -a && source .env && go run .
# Usage (Railway):    set each key in the Railway service environment panel.

# ── Auth ─────────────────────────────────────────────────────────────────────
# PASETO v4 symmetric key — 32 random bytes, hex-encoded (64 hex chars).
# Generate: openssl rand -hex 32
# REQUIRED in production. Server panics at startup if set but invalid.
# Leave blank to run in dev mode (token auth disabled).
DECODER_PASETO_KEY=

# ── mTLS ─────────────────────────────────────────────────────────────────────
# Set to 1 after ALL client agents and the admin app have enrolled device certs.
# Flip to 0 to temporarily allow unauthenticated connections (dev only).
DECODER_MTLS_ENABLED=0

# ── Network ──────────────────────────────────────────────────────────────────
# TCP port to listen on. Railway injects PORT automatically; this is the fallback.
DECODER_PORT=8090

# ── TLS certificates ─────────────────────────────────────────────────────────
# Paths are relative to the working directory (where `go run .` is executed).
# Defaults used if not set:
#   DECODER_SERVER_CERT=certs/server.pem
#   DECODER_SERVER_KEY=certs/server-key.pem
#   DECODER_CA_CERT=certs/intermediate-ca.pem
#   DECODER_CRL_PATH=certs/crl.pem
DECODER_SERVER_CERT=certs/server.pem
DECODER_SERVER_KEY=certs/server-key.pem
DECODER_CA_CERT=certs/intermediate-ca.pem
DECODER_CRL_PATH=certs/crl.pem

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory for presence-log.json, agent-policy.json, screenshots/
DECODER_DATA_DIR=.

# ── Audit log ────────────────────────────────────────────────────────────────
# Append-only JSONL audit log path. Mode 0600 on creation.
DECODER_AUDIT_LOG=audit.jsonl
